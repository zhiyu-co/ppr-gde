# Copy to .env and source it, or export these variables before running scripts.

# Base model being trained.
MODEL_PATH=/path/to/base-model

# Output checkpoint root. Individual scripts create subdirectories under this.
CKPT_DIR=./checkpoints

# Roleplay parquet dataset root.
DATA_DIR=./data/roleplay

# Auxiliary service models.
CHAR_RM_MODEL_PATH=/path/to/BaichuanCharRM
EMBEDDING_MODEL_PATH=/path/to/embedding-model
REWARD_MODEL_PATH=/path/to/judge-model

# Auxiliary service endpoints used by training and validation.
VLLM_HOST=127.0.0.1
VLLM_PORT=8355
CHAR_RM_HOST=127.0.0.1
CHAR_RM_PORT=8000
EMBEDDING_HOST=127.0.0.1
EMBEDDING_PORT=8356

# GPU placement examples. Override per script if needed.
CUDA_VISIBLE_DEVICES=0,1
N_GPUS_PER_NODE=2

# WandB can be set to offline for reproducible local runs.
WANDB_MODE=offline
